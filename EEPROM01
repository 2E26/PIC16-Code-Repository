; EEPROM01.asm
;
; The first in a series of programs to load 6502 assembly code into ROM memory using a PIC16 MCU
; Loads a fixed set of machine code instructions into ROM starting at 7E00h as well as the
; reset and interrupt vectors at 7FFAh - 7FFFh.
;
; Note that ROM memory is 8000h less than actual computer memory, as current ROM occupies the upper
; 32K of memory available to the 6502.
;
; Based on the MPASM assembler

        LIST                P=16F877A
        #include                <P16F877A.inc>
        #include                "USART.asm"

        __CONFIG _CP_OFF & _WDT_OFF & _PWRTE_ON & _XT_OSC

        CBLOCK 0x20
                D1
                D2
                D3
                Databyte
		AddressL
		AddressH
		Temp
        ENDC

        ORG 0x0000
        GOTO START

        ORG 0x0004
        RETFIE

; Program flow:
;
; 1) initialize USART, initialize GPIO registers, and wait for a key
; 2) display a prompt 
; 3) load program into the EEPROM one byte at a time
; 4) check the EEPROM to ensure the byte written was received
; 5) write the next byte
; 6) loop forever when all bytes have been written
;
; File Register use
;
; PORTA(0): address bit A14
; PORTB: address bits A0 - A7
; PORTC(0-5): A8-A13
; PORTD: data bus bits D0-D7
; PORTE(0): Write Enable
; PORTE(1): Chip Enable
; PORTE(2): Output Enable

START:
        BCF         0x03, 6	    ; set memory bank 1
        BSF         0x03, 5
	MOVLW	    0x00
	MOVWF	    0x86	    ; set PortB to output
	MOVWF	    0x88	    ; set PortD to output
	MOVLW	    0x80	    ; set PortC to output except RC7
	MOVWF	    0x87	    ; configure PORTC
	MOVLW	    0x00	    ; set PortA to output
	MOVWF	    0x85	    ; configure PortA
	MOVLW	    0x00	    ; set PortE to output
	MOVWF	    0x89	    ; configure PortE
	BCF	    0x83, 6	    ; set memory bank 0
	BCF	    0x83, 5
	BSF		0x09, 2		; PORTE /OE high
	BSF		0x09, 1		; PORTE /CE high
	BSF		0x09, 0		; PORTE /WE high

	; now, write the following program to EEPROM starting at 0x7E00
	; which will show up in computer memory 0xFE00
	; 0xA9018D0002A9058D0102A9088D02024C00FE
	;
	; start:
	; LDA	$01
	; STA	$0200
	; LDA	$05
	; STA	$0201
	; LDA	$08
	; STA	$0202
	; JMP	start

    CALL        USART_Init
	CALL	    Delay
	CALL	    EEPROM_StartMessage
	CALL	    USART_GetByte
	MOVLW	    0x00	    ; set starting address to 0x7E00
	MOVWF	    AddressL
	MOVLW	    0x7E	    ; which will be 0xFE00 in computer
	MOVWF	    AddressH	    ; addressing
	CALL	    EEPROM_SetAddress

	MOVLW	    0xA9
	MOVWF		Databyte
	CALL		EEPROM_WriteByte

LOOP:
	GOTO	    LOOP

Delay:	MOVLW	50		    ; delay routine
	MOVWF	D1		    ; nested loops
Del1:	MOVLW	50		    ; 50 * 50 * 4 = 10,000
	MOVWF	D2
Del2:	MOVLW	4
	MOVWF	D3
Del3:	NOP
	DECFSZ	D3, F
	GOTO	Del3
	DECFSZ	D2, F
	GOTO	Del2
	DECFSZ	D1, F
	GOTO	Del1
	RETURN

EEPROM_SetAddress:
	BCF	0x03, 5			; select bank 0
	BCF	0x03, 6
	MOVF	AddressL, 0		; grab the low byte of address stored in memory
	MOVWF	0x06			; store it in PORTB
	MOVF	0x07, 0			; store PORTC in W
	ANDLW	0xC0			; clear out all but the two high bits
	MOVWF	Temp			; and store it in memory
	MOVF	AddressH, 0		; grab the high byte of address stored in memory
	ANDLW	0x3F			; mask out the two highest bits
	IORWF	Temp			; restore the two high bits originally in PORTC
	MOVWF	0x07			; write the address to PORTC 0-5, preserving TX/RX bits
	BTFSC	AddressH, 6		; if bit 6 == 1
	BSF	0x05, 0			; then make RA0 = 1
	BTFSS	AddressH, 6		; else, if bit 6 == 0
	BCF	0x05, 0			; then make RA0 = 0
	RETURN

EEPROM_StartMessage:
        MOVLW                'P'
        CALL                USART_SendByte
        MOVLW                'r'
        CALL                USART_SendByte
        MOVLW                'e'
        CALL                USART_SendByte
        MOVLW                's'
        CALL                USART_SendByte
        MOVLW                's'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                'a'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                'k'
        CALL                USART_SendByte
        MOVLW                'e'
        CALL                USART_SendByte
        MOVLW                'y'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                't'
        CALL                USART_SendByte
        MOVLW                'o'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                'l'
        CALL                USART_SendByte
        MOVLW                'o'
        CALL                USART_SendByte
        MOVLW                'a'
        CALL                USART_SendByte
        MOVLW                'd'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                'E'
        CALL                USART_SendByte
        MOVLW                'E'
        CALL                USART_SendByte
        MOVLW                'P'
        CALL                USART_SendByte
        MOVLW                'R'
        CALL                USART_SendByte
        MOVLW                'O'
        CALL                USART_SendByte
        MOVLW                'M'
        CALL                USART_SendByte
        MOVLW                '.'
        CALL                USART_SendByte
	RETURN
	
EEPROM_WriteMessage:
        MOVLW                'W'
        CALL                USART_SendByte
        MOVLW                'r'
        CALL                USART_SendByte
        MOVLW                'o'
        CALL                USART_SendByte
        MOVLW                't'
        CALL                USART_SendByte
        MOVLW                'e'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte
        MOVLW                'b'
        CALL                USART_SendByte
        MOVLW                'y'
        CALL                USART_SendByte
        MOVLW                't'
        CALL                USART_SendByte
        MOVLW                'e'
        CALL                USART_SendByte
        MOVLW                ' '
        CALL                USART_SendByte

EEPROM_WriteByte:
		MOVF				Databyte, 0			; take the data to be written
		MOVWF				0x08				; write it to port D
		BCF					0x09, 1				; /CE low
		NOP
		NOP
		BCF					0x09, 0				; /WE low
		NOP
		NOP
		BSF					0x09, 1				; /CE, /WE high
		BSF					0x09, 0
		CALL				Delay
		RETURN
	
        END
